{
  "name": "@stratium/job-runner",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm exec tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "dependencies": {
    "@redis/client": "^1.6.1",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
