{
  "name": "@stratium/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests",
    "test:coverage": "pnpm exec vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "^6.19.2",
    "@stratium/shared": "workspace:*",
    "@stratium/trading-core": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
