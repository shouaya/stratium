{
  "name": "@stratium/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm exec tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-specifier-resolution=node dist/apps/api/src/index.js",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests",
    "test:coverage": "pnpm exec vitest run --coverage",
    "test:coverage:compat": "pnpm exec vitest run --config vitest.compat.config.ts --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "^6.19.2",
    "@redis/client": "^1.6.1",
    "@stratium/shared": "workspace:*",
    "@stratium/trading-core": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
