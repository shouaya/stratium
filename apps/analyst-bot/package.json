{
  "name": "@stratium/analyst-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm exec tsc -p tsconfig.json",
    "run": "tsx src/index.ts",
    "run:once": "tsx src/index.ts --once",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
