{
  "name": "@stratium/batch",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "clear:kline": "tsx src/clear-market-history.ts",
    "dev": "tsx watch src/index.ts",
    "import:hyperliquid-day": "tsx src/import-hyperliquid-day.ts",
    "import:s3": "tsx src/import-from-s3.ts",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@aws-sdk/client-s3": "^3.862.0",
    "@aws-sdk/client-sqs": "^3.862.0"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
