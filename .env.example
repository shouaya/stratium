POSTGRES_DB=stratium
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/stratium?schema=public
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
WEB_HOST_PORT=5000
API_HOST_PORT=6100
JOB_RUNNER_HOST_PORT=4300
TRADER_MCP_HOST_PORT=4600
ADMINER_HOST_PORT=18080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
SESSION_TTL_MS=28800000
API_RATE_LIMIT_MAX=240
API_RATE_LIMIT_WINDOW=1 minute
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=1 minute
TRADING_RATE_LIMIT_MAX=60
TRADING_RATE_LIMIT_WINDOW=1 minute
DEFAULT_FRONTEND_PASSWORD=demo123456
DEFAULT_ADMIN_PASSWORD=admin123456
# Browser-facing API URL used by the web app in the user's browser.
# Leave empty for same-origin deployments behind /api and /ws.
NEXT_PUBLIC_API_BASE_URL=
# Container-to-container API URL used by services inside Docker Compose.
STRATIUM_API_BASE_URL=http://api:4000
STRATIUM_MCP_HOST=0.0.0.0
STRATIUM_MCP_PATH=/mcp
STRATIUM_MCP_CORS_ORIGIN=*
STRATIUM_MCP_DEBUG_LOG_PATH=logs/trader-mcp-http.ndjson
HYPERLIQUID_COINS=BTC
HYPERLIQUID_CANDLE_INTERVAL=1m
# Flush closed Hyperliquid candles and volume rows to PostgreSQL every 60s by default.
MARKET_PERSIST_INTERVAL_MS=60000
# Disable live market adapter connections when running isolated feature tests.
DISABLE_LIVE_MARKET_DATA=false
# Disable Redis-backed batch job state feed when running isolated tests without Redis.
DISABLE_BATCH_JOB_STATE_FEED=false
