{
  "name": "stratium",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @stratium/api --filter @stratium/web dev",
    "job-runner:dev": "pnpm --filter @stratium/job-runner dev",
    "lint": "pnpm -r lint",
    "postinstall": "pnpm exec prisma generate",
    "prisma:generate": "pnpm exec prisma generate",
    "db:push": "pnpm exec prisma db push",
    "db:seed": "pnpm exec prisma db seed",
    "seed:symbol-configs": "node prisma/seed-symbol-configs.mjs",
    "test:feature": "pnpm exec vitest run --config vitest.feature.config.ts",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@fastify/websocket": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@prisma/client": "^6.19.2",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "fastify": "^5.2.1",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
