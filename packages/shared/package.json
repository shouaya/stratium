{
  "name": "@stratium/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm exec tsc -p tsconfig.json",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests"
  }
}
